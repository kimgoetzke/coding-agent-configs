{
  version: 1,

  // Rules match normalized atomic commands.
  // Default behavior: exact match after normalization.
  // `*` acts as a wildcard within the normalized command string.
  // If both lists match, `block` wins.
  // Rules may be plain strings or objects with an optional note.
  // For `block` rules, notes should be remediation guidance.
  // For `confirm` rules, notes should be approval hints.

  block: [
    "rm -rf /",
    "mkfs *",
    "dd if=* of=/dev/*",
    {
      match: "git push --force*",
      note: "Force-pushes are never allowed here. Create a new branch or use a normal push.",
    },
    {
      match: "python*",
      note: "Python is not available in this environment and you must not install it.",
    },
    "git push *",
    "chmod -R 777 *",
    "chown -R * /",
    "docker system prune -a*",
    "shutdown *",
    "systemctl poweroff",
    "reboot",
  ],

  confirm: [
    "sudo *",
    "rm *",
    "mv *",
    "cp -r *",
    "git push *",
    "git reset --hard*",
    "git clean -fd*",
    "docker rm *",
    "docker rmi *",
    "docker compose down*",
    {
      match: "kubectl delete *",
      note: "Double-check cluster, namespace, and target before continuing.",
    },
    "pnpm remove *",
  ],
}
